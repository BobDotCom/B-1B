<animation>
	<type>knob</type>
	 <object-name>M.1_switch</object-name>
	<property>controls/switches/iff/mode_1</property>
	<factor>20</factor>
	<center>
		<x-m>0.00627</x-m>
		<y-m>-0.026</y-m>
		<z-m>0.006</z-m>
	</center>
	 <axis>
		 <x>0.0</x>
		 <y>-1.0</y>
		 <z>0.0</z>
	 </axis>
         <action>
		 <binding>
			 <command>property-adjust</command>
			 <property>controls/switches/iff/mode_1</property>
			 <min>-1</min>
			 <max>1</max>
		 </binding>
	 </action>
	<release>
		<binding>
			<command>property-adjust</command>
			<property>controls/switches/iff/mode_1</property>
			<step>0</step>
			<min>-1</min>
			<max>0</max>
		</binding>
	</release>
</animation>

