    <object-name>Flt-Ctrl-Pwr</object-name>
    <object-name>Flap-Slat-Resest</object-name>
    <object-name>PTCH-AUG</object-name>
    <object-name>PTCH-TRIM</object-name>
    <object-name>ROLL-AUG</object-name>
    <object-name>ROLL-TRIM</object-name>
    <object-name>SMCS-Reset</object-name>
    <object-name>SPD-BRK</object-name>
    <object-name>SPOILERS</object-name>
    <object-name>YAW-AUG</object-name>
    <object-name>YAW-TRIM</object-name>
    <object-name>ALT-WG-SWP</object-name>
    <object-name>4screws</object-name>
  </animation>

  <animation>
    <type>material</type>
    <object-name>Flt-Ctrl-Pwr</object-name>
    <object-name>Flap-Slat-Resest</object-name>
    <object-name>PTCH-AUG</object-name>
    <object-name>PTCH-TRIM</object-name>
    <object-name>ROLL-AUG</object-name>
    <object-name>ROLL-TRIM</object-name>
    <object-name>SMCS-Reset</object-name>
    <object-name>SPD-BRK</object-name>
    <object-name>SPOILERS</object-name>
    <object-name>YAW-AUG</object-name>
    <object-name>YAW-TRIM</object-name>
    <object-name>ALT-WG-SWP</object-name>
	 <emission>
		 <red>0.9</red>
		 <green>0.5</green>
		 <blue>0.9</blue>
		 <factor-prop>controls/lighting/centre_console</factor-prop>
	</emission>
  </animation>

<animation>
	<type>knob</type>
	 <object-name>ROLL-AUG</object-name>
	<property>controls/switches/Roll-aug-switch</property>
	<factor>30</factor>
	 <center>
		 <x-m>-0.0356</x-m>
		 <y-m>-0.0338</y-m>
		 <z-m>0.0015/</z-m>
    	 </center>
	 <axis>
		 <x>0.0</x>
		 <y>-1.0</y>
		 <z>0.0</z>
	 </axis>


	 <action>
		 <binding>
			 <command>property-adjust</command>
			 <property>controls/switches/Roll-aug-switch</property>
			 <min>0</min>
			 <max>2</max>
		 </binding>
	 </action>
	<release>
		<binding>
			<command>property-adjust</command>
			<property>controls/switches/Roll-aug-switch</property>
			<step>0</step>
			<min>0</min>
			<max>1</max>
		</binding>
	</release>
</animation>

