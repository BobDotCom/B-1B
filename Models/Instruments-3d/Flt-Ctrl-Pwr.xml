<animation> 
 <type>knob</type> 
  <object-name>ALT-WG-SWP</object-name>
  <property>controls/switches/alt-wing-sweep</property>
	<factor>35</factor>
	<center>
		<x-m>-0.000958</x-m>
		<y-m>-0.0488</y-m>
		<z-m>0.01251</z-m>
	</center>
	 <axis>
		 <x>0.0</x>
		 <y>0.0</y>
		 <z>-1.0</z>
	 </axis>
	<action>
		<binding>
			<command>property-adjust</command>
			<property>controls/switches/alt-wing-sweep</property>  
                        <min>0</min> 
                        <max>3</max>			
		</binding>
	</action>
	<release> 
		<binding>
			<command>property-adjust</command>
			<property>controls/switches/alt-wing-sweep</property>
                        <step>0</step> 
                        <min>0</min> 
                        <max>2</max> 
		</binding>
	</release>
      </animation>

