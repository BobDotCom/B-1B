<PropertyList>

 <path>hud_mach.ac</path>

<animation>
	 <type>rotate</type>
	 <object-name>Mach_off_marker</object-name>
	 <property>systems/electrical/bus/ac-2/voltage</property>
	 <interpolation>
		 <entry>
			 <ind>0.0</ind>
			 <dep>0.0</dep>
		 </entry>

		 <entry>
			 <ind>200.0</ind>
			 <dep>-0.0</dep>
		 </entry>
		 <entry>
			 <ind>230.0</ind>
			 <dep>-60.0</dep>
		 </entry>
	 </interpolation>
	 <axis>
		 <x>1.0</x>
		 <y>0.0</y>
		 <z>0.0</z>
	 </axis>
	 <center>
		 <x-m> 0.005317</x-m>
		 <y-m>-0.556</y-m>
		 <z-m>-0.02344</z-m>
  	 </center>
 </animation>

<animation>
	 <type>rotate</type>
	 <object-name>Airspeed_off_marker</object-name>
	 <property>systems/electrical/bus/ac-2/voltage</property>
	 <interpolation>
		 <entry>
			 <ind>0.0</ind>
			 <dep>0.0</dep>
		 </entry>

		 <entry>
			 <ind>200.0</ind>
			 <dep>-0.0</dep>
		 </entry>
		 <entry>
			 <ind>230.0</ind>
			 <dep>-60.0</dep>
		 </entry>
	 </interpolation>
	 <axis>
		 <x>-1.0</x>
		 <y>0.0</y>
		 <z>0.0</z>
	 </axis>
	 <center>
		 <x-m> 0.004989</x-m>
		 <y-m>-0.556</y-m>
		 <z-m>0.03977</z-m>
  	 </center>
 </animation>


 <animation>
   <type>textranslate</type>
   <object-name>ind_mach1</object-name>
   <property>systems/computers/adc_switch/indicated_mach_output</property>
<interpolation>
	<entry>
		<ind>0</ind>
		<dep>0.05</dep>
     </entry>
     <entry>
             <ind>0.1</ind>
             <dep>0</dep>
     </entry>
     <entry>
	     <ind>1.5</ind>
	     <dep>-0.720</dep>
     </entry>
</interpolation>
  <axis>
   <x>0</x>
   <y>1</y>
   <z>0</z>
  </axis>
  <center>
	  <x-m>0.00</x-m>
	  <y-m>0.00</y-m>
	  <z-m>0.00</z-m>
   </center>
 </animation>

 <animation>
	 <type>textranslate</type>
	 <object-name>ind_knots1</object-name>
	 <property>systems/computers/adc_switch/indicated_airspeed_knts_output</property>
	 <interpolation>
		 <entry>
			 <ind>0</ind>
			 <dep>0.05</dep>
		 </entry>
		 <entry>
			 <ind>100</ind>
			 <dep>0</dep>
		 </entry>
		 <entry>
			 <ind>900</ind>
			 <dep>-0.800</dep>
		 </entry>
</interpolation>
		 <axis>
			 <x>0</x>
			 <y>1</y>
			 <z>0</z>
		 </axis>
		 <center>
			 <x-m>0.00</x-m>
			 <y-m>0.00</y-m>
			 <z-m>0.00</z-m>
		 </center>
 </animation>

<animation>
	<type>knob</type>
	 <object-name>set_mach</object-name>
	<property>controls/switches/target-mach</property>
	<factor>30</factor>
	<center>
		<x-m>0.005</x-m>
		<y-m>-0.5423</y-m>
		<z-m>-0.09183</z-m>
	</center>
	 <axis>
		 <x>0.0</x>
		 <y>1.0</y>
		 <z>0.0</z>
	 </axis>


	 <action>
		 <binding>
			 <command>property-adjust</command>
			 <property>controls/switches/target-mach</property>
			 <min>-1</min>
			 <max>1</max>
		 </binding>
	 </action>
	<release>
		<binding>
			<command>property-adjust</command>
			<property>controls/switches/target-mach</property>
			<step>0</step>
			<min>0</min>
			<max>0</max>
		</binding>
	</release>

</animation>

<animation>
	<type>knob</type>
	 <object-name>set_speed</object-name>
	<property>controls/switches/target-speed</property>
	<factor>30</factor>
	<center>
		<x-m>0.005</x-m>
		<y-m>-0.5423</y-m>
		<z-m>-0.09183</z-m>
	</center>
	 <axis>
		 <x>0.0</x>
		 <y>1.0</y>
		 <z>0.0</z>
	 </axis>


	 <action>
		 <binding>
			 <command>property-adjust</command>
			 <property>controls/switches/target-speed</property>
			 <min>-1</min>
			 <max>1</max>
		 </binding>
	 </action>
	<release>
		<binding>
			<command>property-adjust</command>
			<property>controls/switches/target-speed</property>
			<step>0</step>
			<min>0</min>
			<max>0</max>
		</binding>
	</release>
</animation>



<animation>
	<type>textranslate</type>
	<object-name>macfuel1.002</object-name>
	<property>autopilot/settings/target-speed-kt</property>
	<factor>0.001</factor>
	<step>100</step>
	<axis>
		<x>0</x>
		<y>1</y>
		<z>0</z>
	</axis>
</animation>

<animation>
	<type>textranslate</type>
	<object-name>macfuel2.002</object-name>
	<property>autopilot/settings/target-speed-kt</property>
	<factor>0.01</factor>
	<step>10</step>
	<axis>
		<x>0</x>
		<y>1</y>
		<z>0</z>
	</axis>
</animation>

<animation>
	<type>textranslate</type>
	<object-name>macfuel3.002</object-name>
	<property>autopilot/settings/target-speed-kt</property>
	<factor>0.1</factor>
	<step>1</step>
	<axis>
		<x>0</x>
		<y>1</y>
		<z>0</z>
	</axis>
 </animation>

 <animation>
	 <type>material</type>
	 <object-name>ind_knots1</object-name>
	 <object-name>ind_mach1</object-name>
	 <object-name>ind_alt_lmob.003</object-name>
	 <object-name>Mach_command_single</object-name>
	 <object-name>Mach_command_ten</object-name>
	 <object-name>Mach_command_hundred</object-name>
	 <object-name>Mach_command_marker</object-name>
	 <object-name>Mach_off_marker</object-name>
	 <object-name>Airspeed_command_single</object-name>
	 <object-name>Airspeed_command_ten</object-name>
	 <object-name>Airspeed_command_hundred</object-name>
	 <object-name>Airspeed_command_marker</object-name>
	 <object-name>Airspeed_off_marker</object-name>
	 <object-name>set_speed</object-name>
	 <object-name>set_mach</object-name>
	 <emission>
		 <red>0.9</red>
		 <green>0.5</green>
		 <blue>0.9</blue>
		 <factor-prop>controls/lighting/AFCS_indexers_pilot</factor-prop>
	</emission>
</animation>


</PropertyList>
