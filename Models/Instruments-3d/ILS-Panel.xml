 <animation>
  <type>textranslate</type>
  <object-name>drum-1</object-name>
  <property>/instrumentation/nav[0]/frequencies/selected-mhz</property>
		<factor>0.001</factor>
		<offset>-100</offset>
		<step>100</step>
  <axis>
   <x>0</x>
   <y>-1</y>
   <z>0</z>
  </axis>
 </animation>


<animation>
	<type>knob</type>
	<object-name>units-knob</object-name>
	<property>instrumentation/nav[0]/frequencies/selected-mhz</property>
	<interpolation>
		<entry>
			<ind>108.0</ind>
			<dep>0.0</dep>
		</entry>
		<entry>
			<ind>118.0</ind>
			<dep>-180.0</dep>
		</entry>
	</interpolation>
	<axis>
		<x>0.0</x>
		<y>0.0</y>
		<z>1.0</z>
	</axis>
	<center>
		<x-m>0.0</x-m>
		<y-m>-0.0353</y-m>
		<z-m>0.0061</z-m>
	</center>
	<action>			
		<button>0</button>
		<repeatable>true</repeatable>
		<binding>
			<command>property-adjust</command>
			<property>instrumentation/nav[0]/frequencies/selected-mhz</property>
                        <min>108</min>
                        <max>118</max>
                        <factor>1</factor>
		</binding>
	</action>
</animation>

<animation>
	<type>knob</type>
	<object-name>deci-knob</object-name>
	<property>instrumentation/nav[0]/frequencies/selected-mhz</property>
	<interpolation>
		<entry>
			<ind>108.0</ind>
			<dep>0.0</dep>
		</entry>
		<entry>
			<ind>118</ind>
			<dep>-3600.0</dep>
		</entry>
	</interpolation>
	<axis>
		<x>0.0</x>
		<y>0.0</y>
		<z>1.0</z>
	</axis>
	<center>
		<x-m>0.0</x-m>
		<y-m>0.0393</y-m>
		<z-m>0.0056</z-m>
	</center>
	<action>			
		<button>0</button>
		<repeatable>true</repeatable>
		<binding>
			<command>property-adjust</command>
			<property>instrumentation/nav[0]/frequencies/selected-mhz</property>
                        <min>0</min>
                        <max>118</max>
                        <factor>0.01</factor>
		</binding>
	</action>
</animation>

<animation>
	<type>knob</type>
	<object-name>power-switch</object-name>
	<property>instrumentation/nav[0]/power-btn</property>
	<interpolation>
		<entry>
			<ind>0.0</ind>
			<dep>0.0</dep>
		</entry>
		<entry>
			<ind>1</ind>
			<dep>30.0</dep>
		</entry>
	</interpolation>
	<axis>
		<x>0.0</x>
		<y>0.0</y>
		<z>-1.0</z>
	</axis>
	<center>
		<x-m>0.0</x-m>
		<y-m>-0.0353</y-m>
		<z-m>-0.0006</z-m>
	</center>
	<action>			
		<button>0</button>
		<repeatable>true</repeatable>
		<binding>
			<command>property-adjust</command>
			<property>instrumentation/nav[0]/power-btn</property>
                        <min>0</min>
                        <max>1</max>
                        <factor>1</factor>
		</binding>
	</action>
</animation>

