<?xml version="1.0"?>

<PropertyList>
<path>ILS-Panel.ac</path>

<animation>
  <type>textranslate</type>
  <object-name>drum-5</object-name>
  <property>/instrumentation/nav[0]/frequencies/selected-mhz</property>
		<factor>10</factor>
		<offset>-0.01</offset>
		<step>0.01</step>
  <axis>
   <x>0</x>
   <y>-1</y>
   <z>0</z>
  </axis>
 </animation>

