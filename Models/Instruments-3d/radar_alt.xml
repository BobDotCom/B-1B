<PropertyList>

 <path>radar_alt.ac</path>

 <animation>
   <type>rotate</type>
   <object-name>needle</object-name>
   <property>position/altitude-agl-ft</property>
<interpolation>
     <entry>
       <ind>0</ind>
       <dep>-5</dep>
     </entry>
     <entry>
       <ind>500</ind>
       <dep>-170</dep>
     </entry>
     <entry>
       <ind>1000</ind>
       <dep>-205</dep>
     </entry>
     <entry>
	     <ind>35000</ind>
	     <dep>-324</dep>
     </entry>
</interpolation>
  <axis>
   <x>1</x>
   <y>0</y>
   <z>0</z>
  </axis>
  <center>
	  <x-m>0.041</x-m>
	  <y-m>-0.00</y-m>
	  <z-m>-0.00</z-m>
   </center>
 </animation>

  <animation>
    <type>rotate</type>
    <object-name>bug</object-name>
    <property>instrumentation/radar-altimeter/target</property>
    <interpolation>
      <entry><ind>0</ind><dep>0</dep></entry>
      <entry><ind>10</ind><dep>-73</dep></entry>
      <entry><ind>20</ind><dep>-145</dep></entry>
      <entry><ind>30</ind><dep>-218</dep></entry>
      <entry><ind>40</ind><dep>-290</dep></entry>
    </interpolation>
    <axis>
      <x> -1 </x>
      <y>  0 </y>
      <z>  0 </z>
    </axis>
  </animation>

  <animation>
        <type>knob</type>
        <object-name>AGL_set</object-name>
        <property>instrumentation/radar-altimeter/target</property>
        <factor>10</factor>
        <center>
            <x-m>0.009203</x-m>
            <y-m>-0.031464</y-m>
            <z-m>-0.031657</z-m>
        </center>
        <axis>
            <x>1</x>
            <y>0</y>
            <z>0</z>
        </axis>
        <action>
            <binding>
                <command>property-adjust</command>
                <property>instrumentation/radar-altimeter/target</property>
                <min>0</min>
                <max>40</max>
                <wrap>false</wrap>
           </binding>
        </action>
    </animation>


 <animation>
	 <type>material</type>
	 <object-name>needle</object-name>
	 <object-name>Face</object-name>
     <object-name>bug</object-name>
	 <emission>
		 <red>0.9</red>
		 <green>0.5</green>
		 <blue>0.9</blue>
		 <factor-prop>controls/lighting/AFCS_indexers_pilot</factor-prop>
	</emission>
</animation>


</PropertyList>
