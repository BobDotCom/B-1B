    <animation>
        <type>slider</type>
        <object-name>alt_off</object-name>
        <property>controls/switches/apmode/alt</property>
        <factor>-0.002</factor>
        <axis>
            <x>1</x>
            <y>0</y>
            <z>0</z>
        </axis>
        <action>
            <binding>
                <command>property-toggle</command>
                <property>controls/switches/apmode/alt</property>
            </binding>
