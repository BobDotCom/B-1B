<?xml version="1.0"?>
<!--
sweat by maggse
    -->
<PropertyList>

 <path>apmode.ac</path>

<animation>
	 <type>material</type>
	 <object-name>take_comd_off</object-name>
	 <object-name>engage_off</object-name>
	 <object-name>as_off</object-name>
	 <object-name>flt_dir_off</object-name>
	 <object-name>mach_off</object-name>
	 <object-name>terr_flw_off</object-name>
	 <object-name>auto_throt_off</object-name>
	 <object-name>alt_off</object-name>
	 <object-name>take_comd_on</object-name>
	 <object-name>engage_on</object-name>
	 <object-name>as_on</object-name>
	 <object-name>flt_dir_on</object-name>
	 <object-name>mach_on</object-name>
	 <object-name>terr_flw_on</object-name>
	 <object-name>auto_throt_on</object-name>
	 <object-name>alt_on</object-name>
	 <emission>
		 <red>0.9</red>
		 <green>0.5</green>
		 <blue>0.9</blue>
        <factor-prop>controls/switches/annunciators-norm</factor-prop>
	</emission>
</animation>


<!-- take comd buttion -->


      <animation>
	      <type>select</type>
	      <object-name>take_comd_off</object-name>
              <condition> 
               <or>
               <greater-than> 
                <property>systems/electrical/bus/ac-2/voltage</property>
                <value>220</value>
               </greater-than> 
               <greater-than> 
                <property>systems/electrical/bus/ac-3/voltage</property>
                <value>220</value>
               </greater-than>
               </or> 
              </condition> 
      </animation>


 <animation>
	 <type>pick</type>
	 <object-name>take_comd_off</object-name>
	 <action>
		 <button>0</button>
		 <repeatable>true</repeatable>
		 <interval-sec>0.1</interval-sec>
		 <binding>
			 <command>property-toggle</command>
			 <property>controls/switches/apmode/take_comd</property>
		 </binding>
		 <binding>
			      <command>nasal</command>
			      <script>b1b.checkapmode()</script>
		 </binding>
	 </action>
</animation>

      <animation>
	      <type>translate</type>
	      <object-name>take_comd_on</object-name>
              <property>controls/switches/apmode/take_comd</property>
  	      <factor>0.0005</factor>
 	      <axis>
    	      <x>1</x>
   	      <y>0</y>
   	      <z>0</z>
   	      </axis>
      </animation>


