<PropertyList>

<path>alter_throt.ac</path>

<animation> 
	<type>select</type>
	<object-name>TTO_light</object-name> 
        <condition> 
         <and> 
         <equals>  
          <property>controls/flight/elevator-trim</property>
           <value>-0.5</value>
         </equals>
         <equals>  
          <property>controls/flight/rudder</property>
           <value>0.0</value>
         </equals>
         <equals>  
          <property>controls/flight/flaps</property>
           <value>0.5</value>
         </equals>
         <equals>  
          <property>controls/switches/TTO_button</property>
           <value>1.0</value>
         </equals>
         </and>
        </condition> 
 </animation>

<animation> 
 <type>knob</type> 
  <object-name>eng_0</object-name>
  <property>controls/switches/eng_0_stby_throttle</property>
	<factor>30</factor>
	<center>
		<x-m>0.009</x-m>
		<y-m>0.275047</y-m>
		<z-m>0.063526</z-m>
	</center>
	 <axis>
		 <x>0.0</x>
		 <y>1.0</y>
		 <z>0.0</z>
	 </axis>
	<action>
		<binding>
			<command>property-adjust</command>
			<property>controls/switches/eng_0_stby_throttle</property>  
                        <min>-1</min> 
                        <max>1</max>			
		</binding>
	</action>
	<release> 
		<binding>
			<command>property-assign</command>
			<property>controls/switches/eng_0_stby_throttle</property> 
                        <value>0</value> 
		</binding>
	</release>
      </animation> 


