<PropertyList>

<path>alter_throt.ac</path>

<animation> 
	<type>select</type>
	<object-name>TTO_light</object-name> 
        <condition> 
         <and> 
         <equals>  
          <property>controls/flight/elevator</property>
           <value>-0.7</value>
         </equals>
         <equals>  
          <property>controls/flight/rudder</property>
           <value>0.0</value>
         </equals>
         <equals>  
          <property>controls/flight/flaps</property>
           <value>0.5</value>
         </equals>
         <equals>  
          <property>controls/switches/TTO_button</property>
           <value>1.0</value>
         </equals>
         </and>
        </condition> 
 </animation> 

<animation> 
 <type>slider</type> 
  <object-name>TTO</object-name>
  <property>controls/switches/TTO_button</property>
    <factor>0.008</factor> 
 	<axis>
		<x>-1</x>
		<y>0</y>
		<z>0</z>
	</axis> 
	<action>
		<binding>
			<command>property-assign</command>
			<property>controls/switches/TTO_button</property> 
			<value>1</value>			
		</binding>
		<binding>
	        <command>property-assign</command>
		<property>controls/flight/elevator</property> 
                <value>-0.7</value>
		</binding>
		<binding>
	        <command>property-assign</command>
		<property>controls/flight/rudder</property> 
                <value>0.0</value>
		</binding>
	</action>
	<release> 
		<binding>
			<command>property-adjust</command>
			<property>controls/switches/TTO_button</property> 
                        <step>0</step> 
                        <min>0</min> 
                        <max>0</max>
		</binding>
	</release>

</animation>

 <animation>
	<type>material</type>
	<object-name>eng_0</object-name>
	<object-name>eng_1</object-name>
    <object-name>eng_2</object-name>
	<object-name>eng_3</object-name>
    <object-name>ptch_gain</object-name>
    <object-name>roll_limit</object-name>
	<object-name>stall_inhib</object-name>
	<object-name>stby_ptch</object-name>
    <object-name>trim</object-name>
	<object-name>TTO</object-name>
	 <object-name>4Screws</object-name>
	 <object-name>tto</object-name>
	<emission>
		<red>0.9</red>
		<green>0.5</green>
		<blue>0.9</blue>
		<factor-prop>controls/lighting/centre_console</factor-prop>
	</emission>
</animation>

</PropertyList>
