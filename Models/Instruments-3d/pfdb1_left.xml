<PropertyList>

 	<path>pfdb1.ac</path>

    <effect>
        <inherits-from>Aircraft/B-1B/Models/Effects/displays/crt</inherits-from>
        <object-name>AI</object-name>
    </effect>

    <animation>
        <object-name>AI</object-name>
        <type>material</type>
        <ambient>
            <red>  1</red>
            <green>1</green>
            <blue> 1</blue>
        </ambient>
        <diffuse>
            <red>  1</red>
            <green>1</green>
            <blue> 1</blue>
        </diffuse>
        <emission>
            <red>  1</red>
            <green>1</green>
            <blue> 1</blue>
        </emission>
    </animation>

  <animation>
        <type>knob</type>
        <object-name>BRT</object-name>
        <property>controls/pfd/brightness</property>
	<interpolation>
		<entry>
			<ind>0</ind>
			<dep>0.0</dep>
		</entry>
		<entry>
			<ind>2</ind>
			<dep>360.0</dep>
		</entry>
	</interpolation>
        <center>
            <x-m>0.049427</x-m>
            <y-m>-0.055447</y-m>
            <z-m>-0.099651</z-m>
        </center>
        <axis>
            <x>-1</x>
            <y>0</y>
            <z>0</z>
        </axis>
        <action>
            <binding>
                <command>property-adjust</command>
                <property>controls/pfd/brightness</property> 
                <factor>0.03</factor>
                <min>0</min>
                <max>2</max>
                <wrap>false</wrap>
           </binding>
        </action>
    </animation>

  <animation>
        <type>knob</type>
        <object-name>CNTRST</object-name>
        <property>controls/pfd/contrast-new</property>
    <interpolation>
        <entry>
            <ind>0.25</ind>
            <dep>0.0</dep>
        </entry>
        <entry>
            <ind>1.7</ind>
            <dep>360.0</dep>
        </entry>
    </interpolation>
        <center>
            <x-m>0.049427</x-m>
            <y-m>-0.055447</y-m>
            <z-m>-0.099651</z-m>
        </center>
        <axis>
            <x>-1</x>
            <y>0</y>
            <z>0</z>
        </axis>
        <action>
            <binding>
                <command>property-adjust</command>
                <property>controls/pfd/contrast-new</property> 
                <factor>0.02</factor>
                <min>0.25</min>
                <max>1.7</max>
                <wrap>false</wrap>
           </binding>
        </action>
    </animation>


</PropertyList>
