 <animation>
         <object-name>FIRE_DETR</object-name>
	 <type>select</type>
          <condition>
             <and>
         	<greater-than> 
          		 <property>systems/electrical/bus/ess/voltage</property>
          		 <value>220</value>
         	</greater-than>
             <or>
         	<equals> 
          		 <property>/systems/extinguishers/engine[0]/light</property>
          		 <value>1</value>
         	</equals>
         	<equals> 
          		 <property>/systems/extinguishers/engine[1]/light</property>
          		 <value>1</value>
         	</equals>
         	<equals> 
          		 <property>/systems/extinguishers/engine[2]/light</property>
          		 <value>1</value>
         	</equals>
         	<equals> 
          		 <property>/systems/extinguishers/engine[3]/light</property>
          		 <value>1</value>
         	</equals>
             </or>
            </and>
          </condition>

</animation>

 <animation>
         <object-name>FUEL_LOW</object-name>
	 <type>select</type>
          <condition>
             <and>
         	<greater-than> 
          		 <property>systems/electrical/bus/ess/voltage</property>
          		 <value>220</value>
         	</greater-than>
         	<equals> 
          		 <property>systems/failures/annunciators/FUEL_LOW</property>
          		 <value>0</value>
         	</equals>
             <or>
         	<less-than> 
          		 <property>consumables/fuel/tank[6]/level-lbs</property>
          		 <value>1000</value>
         	</less-than>
         	<less-than> 
          		 <property>consumables/fuel/tank[7]/level-lbs</property>
          		 <value>1000</value>
         	</less-than>
             </or>
            </and>
          </condition>
</animation>

