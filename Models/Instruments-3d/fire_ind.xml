            		 <!-- Discharge switches -->

<!-- Left -->

	<animation>
		<type>knob</type>
	 <object-name>switch_lagent</object-name>
	<property>controls/switches/extinguishers/l_agent_switch</property>
        <factor>-30</factor>
		<axis>
			<x> 0 </x>
			<y> 1 </y>
			<z> 0 </z>
		</axis>
	 <center>
		 <x-m>-0.0280</x-m>
		 <y-m>-0.431</y-m>
		 <z-m> 0.077</z-m>
	 </center>
	 <action>
		 <binding>
			 <command>property-adjust</command>
	                 <property>controls/switches/extinguishers/l_agent_switch</property>
                         <factor>1</factor>
			 <min>-1</min>
			 <max>1</max>
		 </binding>
	 </action>
</animation>

<!-- Right -->

	<animation>
		<type>knob</type>
	 <object-name>switch_ragent</object-name>
