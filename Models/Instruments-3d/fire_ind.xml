<!-- ENG_1 -->

 <animation>
	 <type>translate</type>
	 <object-name>ENG_1</object-name>
	 <property>controls/switches/engine_1_fire-bottle-discharge</property>
		<factor>0.002</factor>
		<axis>
			<x>-1 </x>
			<y> 0 </y>
			<z> 0 </z>
		</axis>
	 <center>
		 <x-m>-0.0301</x-m>
		 <y-m>-0.3807</y-m>
		 <z-m> 0.077</z-m>
	 </center>
 </animation>

 <animation>
	 <type>pick</type>
	 <object-name>ENG_1</object-name>
	 <action>
		 <button>0</button>
		 <repeatable>true</repeatable>
		 <interval-sec>0.5</interval-sec>
		 <binding>
			 <command>property-assign</command>
			 <property>controls/switches/engine_1_fire-bottle-discharge</property>
                         <value>1</value>
		 </binding>
		 <binding>
			 <command>property-assign</command>
			 <property>controls/engines/engine[0]/cutoff</property>
                         <value>1</value>
		 </binding>
	 </action>
</animation>

 <animation>
	 <type>select</type>
	 <object-name>rep_fire1</object-name>
	 <condition>
		 <or>
		 <equals>
			 <property>controls/switches/fire</property>
			 <value>1.0</value>
		 </equals>
		 <greater-than>
			 <property>/systems/engines/engine[0]/current_temperature_degC</property>
			 <value>790</value>
		 </greater-than>
	         </or>
	 </condition>
 </animation>

 <animation>
	 <type>translate</type>
	 <object-name>rep_fire1</object-name>
	 <property>controls/switches/engine_1_fire-bottle-discharge</property>
		<factor>0.002</factor>
		<axis>
			<x>-1 </x>
			<y> 0 </y>
			<z> 0 </z>
		</axis>
	 <center>
		 <x-m>-0.0289</x-m>
		 <y-m>-0.379</y-m>
		 <z-m> 0.076</z-m>
	 </center>
 </animation>

 <animation>
	 <type>pick</type>
	 <object-name>rep_fire1</object-name>
	 <action>
		 <button>0</button>
		 <repeatable>true</repeatable>
		 <interval-sec>0.5</interval-sec>
	 </action>
</animation>

 <animation>
	 <type>material</type>
	 <object-name>rep_fire1</object-name>
	 <emission>
		 <red>0.9</red>
		 <green>0.5</green>
		 <blue>0.9</blue>
		 <factor-prop>controls/switches/brightness_switch</factor-prop>
	 </emission>
</animation>

