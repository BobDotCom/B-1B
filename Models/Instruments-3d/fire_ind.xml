<PropertyList>

 <path>fire_ind.ac</path>

 			   <!-- fire test switch -->


<animation> 
 <type>slider</type> 
  <object-name>switch_firetest</object-name>
  <property>controls/switches/extinguishers/fire_test</property>
    <factor>0.002</factor> 
 	<axis>
		<x>-1</x>
		<y>0</y>
		<z>0</z>
	</axis> 
	<action>
		<binding>
			<command>property-assign</command>
			<property>controls/switches/extinguishers/fire_test</property> 
			<value>1</value>			
		</binding>
	</action>
	<release> 
		<binding>
			<command>property-adjust</command>
			<property>controls/switches/extinguishers/fire_test</property> 
                        <step>0</step> 
                        <min>0</min> 
                        <max>0</max>
		</binding>
	</release>

</animation>

				<!-- fire ind -->

<!-- ENG_1 -->

<animation> 
 <type>slider</type> 
  <object-name>ENG_1</object-name>
  <property>controls/switches/extinguishers/engine_1_fire-bottle-discharge</property>
    <factor>0.002</factor> 
 	<axis>
		<x>-1</x>
		<y>0</y>
		<z>0</z>
	</axis> 
	<action>
		<binding>
			<command>property-assign</command>
			<property>controls/switches/extinguishers/engine_1_fire-bottle-discharge</property> 
			<value>1</value>			
		</binding>
	</action>
	<release> 
		<binding>
			<command>property-adjust</command>
			<property>controls/switches/extinguishers/engine_1_fire-bottle-discharge</property> 
                        <step>0</step> 
                        <min>0</min> 
                        <max>0</max>
		</binding>
	</release>
</animation>

 <animation>
	 <type>select</type>
	 <object-name>eng_fire_light1</object-name>
	 <condition>
		 <equals>
			 <property>systems/extinguishers/lights/engine[0]/on</property>
			 <value>1.0</value>
		 </equals>
	 </condition>
 </animation>
<animation>
	 <type>material</type>
	 <object-name>eng_fire_light1</object-name>
	 <emission>
		 <red>0.9</red>
		 <green>0.5</green>
		 <blue>0.9</blue>
		 <factor-prop>controls/switches/extinguishers/brightness_switch</factor-prop>
	 </emission>
</animation>

