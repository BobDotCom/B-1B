<PropertyList>

 <path>terflw_ind.ac</path>


 <!-- terrain follow switch on/off -->

 <animation>
	 <type>rotate</type>
	 <object-name>switch_terflw</object-name>
	 <property>controls/switches/terrain-follow</property>
	 <interpolation>
		 <entry>
			 <ind>0.0</ind>
			 <dep>30.0</dep>
		 </entry>
		 <entry>
			 <ind>1.0</ind>
			 <dep>-30.0</dep>
		 </entry>
	 </interpolation>
	 <axis>
		 <x>0.0</x>
		 <y>1.0</y>
		 <z>0.0</z>
	 </axis>
	 <center>
		 <x-m>-18.46675</x-m>
		 <y-m>-0.01946</y-m>
		 <z-m>-0.14178</z-m>
   </center>
 </animation>

 <!-- clickable buttons block (osg only!) xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-->

 <animation>
	 <type>pick</type>
	 <object-name>switch_terflw</object-name>
	 <action>
		 <button>0</button>
		 <repeatable>true</repeatable>
		 <interval-sec>0.3</interval-sec>
		 <binding>
			 <command>property-toggle</command>
			 <property>controls/switches/terrain-follow</property>
		 </binding>
		 <binding>
			 <command>nasal</command>
			 <script>b1b.ter_follow(0)</script>
		 </binding>
	 </action>
</animation>

