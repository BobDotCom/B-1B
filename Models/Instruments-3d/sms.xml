<!-- Emergency Jettison -->

  <animation>
   <type>rotate</type>
   <object-name>safety.006</object-name>
   <property>controls/switches/safety.006</property>
   <factor>45</factor>
   <min>0</min>
   <max>1</max>
   <center>
    <x-m> 0.00678</x-m>
    <y-m> 0.05850</y-m>
    <z-m>-0.06081</z-m>
   </center>
   <axis>
    <x>0</x>
    <y>-1</y>
    <z>0</z>
   </axis>
  </animation>

  <animation>
   <type>pick</type>
   <object-name>safety.006</object-name>
   <action>
    <button>0</button>
      <binding>
        <command>property-toggle</command>
        <property>controls/switches/safety.006</property>
        <factor>45</factor>
        <min>0</min>
        <max>1</max>
      </binding>
   </action>
 </animation>

 <animation>
   <type>rotate</type>
   <object-name>jettison</object-name>
   <property>armament/oso/auto-release</property>
   <factor>45</factor>
   <min>0</min>
   <max>1</max>
   <center>
    <x-m> 0.00696</x-m>
    <y-m> 0.05882</y-m>
    <z-m>-0.08370</z-m>
   </center>
   <axis>
    <x>0</x>
    <y>-1</y>
    <z>0</z>
   </axis>
  </animation>

  <animation>
   <type>pick</type>
   <object-name>jettison</object-name>
   <action>
    <button>0</button>
      <binding>
       <condition>
        <equals> 
        <property>controls/switches/safety.006</property>
        <value>1</value>
        </equals> 
       </condition>
        <command>property-toggle</command>
        <property>armament/oso/auto-release</property>
        <factor>0</factor>
        <min>0</min>
        <max>1</max>
      </binding>
   </action>
 </animation>

