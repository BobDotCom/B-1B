<?xml version="1.0" encoding="UTF-8"?> 

<PropertyList> 

    <logic>
      <input> 
    	<or> 
    	<equals> 
      	<property>sim/multiplay/generic/float[5]</property> 
      	<value>1</value> 
     	</equals> 
     	<and>
    	<equals> 
      	<property>controls/gear/gear-down</property>
      	<value>1</value> 
     	</equals>
   	 <greater-than> 
     	<property>systems/electrical/bus/ac-3/voltage</property> 
      	<value>220</value> 
    	 </greater-than> 
     	</and>
     	</or>                 
     </input>
     <output>instrumentation/annunciators/nws</output>
    </logic>

    <logic>
      <input> 
    	<and>
    	<equals> 
     	<property>/systems/refuel/contact</property> 
      	<value>1</value> 
     	</equals> 
   	 <greater-than> 
     	<property>systems/electrical/bus/ac-3/voltage</property> 
      	<value>220</value> 
    	 </greater-than> 
    	 </and>                
     	</input>
     <output>instrumentation/annunciators/latched</output>
    </logic>
 
    <logic>
      <input> 
    	<and>
    	<equals> 
     	<property>/systems/refuel/contact</property> 
      	<value>0</value> 
     	</equals>
   	 <equals> 
      	<property>sim/multiplay/generic/float[5]</property>  
      	<value>1</value> 
     	</equals>
    	<greater-than> 
     	<property>systems/electrical/bus/ac-3/voltage</property> 
      	<value>220</value> 
     	</greater-than>
    	</and>               
     	</input>
     <output>instrumentation/annunciators/disc</output>
    </logic>

    <logic>
      <input> 
       <and>
        <equals>       
	 <property>controls/switches/failures/wing-sweep_lever</property>
	 <value>1</value> 
        </equals>
        <equals>       
         <property>controls/switches/master_caution</property>
	 <value>1</value> 
        </equals>
       </and>                
     </input>
     <output>instrumentation/annunciators/preptoeject</output>
    </logic>

    <logic>
     <input> 
      <and> 
       <or>   
         <greater-than>       
	  <property>surface-positions/flap-pos-norm</property>
	  <value>0.0</value> 
         </greater-than>               
          <greater-than>      
	  <property>gear/gear/position-norm</property>
	  <value>0.0</value> 
         </greater-than> 
        </or>              
         <greater-than>       
	  <property>velocities/airspeed-kt</property>
	  <value>240.0</value>             
       </greater-than>
       </and>
      </input>
      <output>instrumentation/annunciators/reducespeed</output>
 </logic>

    <logic>
     <input> 
      <and>    
         <equals>       
	  <property>surface-positions/flap-pos-norm</property>
	  <value>0.0</value> 
         </equals>               
          <equals>      
	  <property>gear/gear/position-norm</property>
	  <value>1.0</value> 
         </equals>              
         <greater-than>       
	  <property>velocities/groundspeed-kt</property>
	  <value>20.0</value>             
         </greater-than>
       </and>
      </input>
      <output>instrumentation/annunciators/flapwing</output>
 </logic> 

    <logic>
     <input>
        <and>
         <greater-than>
          <property>instrumentation/radar-altimeter/target</property>
          <property>systems/computers/altitude_radars/altitude_radar_switch/current_value</property>
         </greater-than>
         <greater-than>
          <property>systems/computers/altitude_radars/altitude_radar_switch/current_value</property>
           <value>0</value>
         </greater-than>
                <or>
         	<greater-than> 
          	 <property>systems/electrical/bus/ac-3/voltage</property>
          	 <value>220</value>
         	</greater-than>
         	<greater-than> 
          	 <property>systems/electrical/bus/ess/voltage</property>
          	 <value>220</value>
         	</greater-than>
           </or>
        </and>     
      </input>
      <output>instrumentation/annunciators/mindechgt</output>
 </logic> 

    <logic>
     <input> 
      <and>    
         <greater-than>       
	  <property>orientation/pitch-deg</property>
	  <value>10.0</value> 
         </greater-than>               
          <less-than>      
	  <property>velocities/vertical-speed-fps</property>
	  <value>0.0</value> 
         </less-than>              
       </and>
      </input>
      <output>instrumentation/annunciators/stall</output>
 </logic>

    <logic>
     <input> 
	<and>
         <equals>
	  <property>instrumentation/nav/gs-in-range</property>
	  <value>1.0</value> 
         </equals>
         <greater-than>       
	  <property>instrumentation/nav/gs-needle-deflection</property>
	  <value>-0.9</value> 
         </greater-than>               
          <less-than>      
	  <property>instrumentation/nav/gs-needle-deflection</property>
	  <value>0.9</value>
         </less-than>
            <or>
         	<greater-than> 
          	 <property>systems/electrical/bus/ac-3/voltage</property>
          	 <value>220</value>
         	</greater-than>
         	<greater-than> 
          	 <property>systems/electrical/bus/ess/voltage</property>
          	 <value>220</value>
         	</greater-than>
           </or>  
	</and>
      </input> 
      <output>instrumentation/annunciators/glideslope</output>
 </logic>

     <logic>
     <input> 
      <and>    
         <greater-than>       
	  <property>instrumentation/nav/heading-needle-deflection</property>
	  <value>-1.0</value> 
         </greater-than>               
          <less-than>      
	  <property>instrumentation/nav/heading-needle-deflection</property>
	  <value>1.0</value>
         </less-than>
         <equals>
	  <property>gear/gear[4]/wow</property>
	  <value>0.0</value> 
         </equals>
                  <or>
         	<greater-than> 
          	 <property>systems/electrical/bus/ac-3/voltage</property>
          	 <value>220</value>
         	</greater-than>
         	<greater-than> 
          	 <property>systems/electrical/bus/ess/voltage</property>
          	 <value>220</value>
         	</greater-than>
           </or>   
       </and>
      </input>
      <output>instrumentation/annunciators/loc</output>
 </logic>

<!-- SOUND EFFECTS -->

    <logic>
      <input> 
       <or>
        <equals>       
	 <property>controls/switches/fire</property>
	 <value>1</value> 
        </equals>
        <equals>       
	 <property>systems/extinguishers/lights/engine[0]/on</property>
	 <value>1</value> 
        </equals>
        <equals>       
	 <property>systems/extinguishers/lights/engine[1]/on</property>
	 <value>1</value> 
        </equals>
        <equals>       
	 <property>systems/extinguishers/lights/engine[2]/on</property>
	 <value>1</value> 
        </equals>
        <equals>       
	 <property>systems/extinguishers/lights/engine[3]/on</property>
	 <value>1</value> 
        </equals>
        <equals>       
	 <property>systems/extinguishers/lights/l_apu/on</property>
	 <value>1</value> 
        </equals>
        <equals>       
	 <property>systems/extinguishers/lights/r_apu/on</property>
	 <value>1</value> 
        </equals>
        <equals>       
         <property>instrumentation/annunciators/flapwing</property>
	 <value>1</value> 
        </equals>
       </or>                
     </input>
     <output>sound/caution</output>
    </logic>

    <logic>
      <input> 
       <or>
        <equals>       
	 <property>instrumentation/annunciators/reducespeed</property>
	 <value>1</value> 
        </equals>
       </or>                
     </input>
     <output>sound/overspeed</output>
    </logic>

    <logic>
      <input> 
       <or>
        <equals>       
	 <property>controls/switches/eject</property>
	 <value>1</value> 
        </equals>
       </or>                
     </input>
     <output>sound/eject</output>
    </logic>
    
</PropertyList> 