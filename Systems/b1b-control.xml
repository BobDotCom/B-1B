<?xml version="1.0"?>
<system name="B-1B Control">

    <property value="0">/controls/switches/failures/wing-sweep_lever</property>
    <property value="1">/controls/gear/gear-down</property>
    <property value="1">/gear/serviceable</property>
    <property value="0">/systems/flight-controls/flaps/channel-1</property>
    <property value="0">/systems/flight-controls/flaps/channel-2</property>

    <channel name="Wing Sweep">

	<switch name="fcs/sweep-cmd-norm">
		<test value="fcs/sweep-cmd-norm-stuck">
		   /controls/switches/failures/wing-sweep_lever eq 1
		</test>
		<default value="/controls/flight/wing-sweep"/>
        </switch>

	<pure_gain name="fcs/sweep-cmd-norm-stuck">
		<input>fcs/sweep-cmd-norm</input>
		<gain>1</gain>
	</pure_gain> 

        <kinematic name="fcs/sweep-pos-norm">
  <!--      <input>/controls/flight/wing-sweep</input>-->
            <input>fcs/sweep-cmd-norm</input>
            <!-- TODO: Set accurate wing sweep time -->
            <traverse>
                <setting>
                    <position>0</position>
                    <time>0</time>
                </setting>
                <setting>
                    <position>1</position>
                    <time>12</time>
                </setting>
            </traverse>
            <output>/surface-positions/wing-sweep-pos-norm</output>
        </kinematic>
        <fcs_function name="fcs/sweep-pos-deg">
            <function>
                <table>
                    <independentVar lookup="row">fcs/sweep-pos-norm</independentVar>
                    <tableData>
                        0  67.5
                        1  15.0
                    </tableData>
                </table>
            </function>
        </fcs_function>

<!--        <aerosurface_scale name="fcs/sweep-pos-deg">-->
<!--            <input>fcs/sweep-pos-norm</input>-->
<!--            <domain>-->
<!--                <min>0</min>-->
<!--                <max>1</max>-->
<!--            </domain>-->
<!--            <range>-->
<!--                <min>15</min>-->
<!--                <max>67.5</max>-->
<!--            </range>-->
<!--        </aerosurface_scale>-->

    </channel>

    <channel name="Elevon">

        <summer name="fcs/roll-trim-sum">
            <input>fcs/aileron-cmd-norm</input>
            <input>fcs/roll-trim-cmd-norm</input>
            <clipto>
                <min>-1</min>
                <max>1</max>
            </clipto>
        </summer>

        <pure_gain name="fcs/elevon-gain">
            <input>fcs/roll-trim-sum</input>
            <gain>1</gain>
        </pure_gain>

        <summer name="fcs/left-elevon-sum">
            <input>fcs/elevator-cmd-norm</input>
            <input>fcs/pitch-trim-cmd-norm</input>
            <input>-fcs/elevon-gain</input>
            <clipto>
                <min>-1</min>
                <max>1</max>
            </clipto>
        </summer>

        <summer name="fcs/right-elevon-sum">
            <input>fcs/elevator-cmd-norm</input>
            <input>fcs/pitch-trim-cmd-norm</input>
            <input>fcs/elevon-gain</input>
            <clipto>
                <min>-1</min>
                <max>1</max>
            </clipto>
        </summer>

        <aerosurface_scale name="Left Elevator Control">
            <input>fcs/left-elevon-sum</input>
            <range>
                <min>-0.35</min>
                <max>0.35</max>
            </range>
            <output>fcs/left-elevator-pos-rad</output>
        </aerosurface_scale>

		<actuator name="fcs/left-elevator-pos-mech">
            <input>fcs/left-elevator-pos-rad</input>
            <rate_limit sense="decr">0.1</rate_limit> 
            <rate_limit sense="incr">0.1</rate_limit> 
        </actuator>

		<switch name="fcs/left-elevator-pos-input">
			<default value="fcs/left-elevator-pos-mech"/>
			<test logic="AND" value="fcs/left-elevator-pos-hyd">
                                /systems/hydraulic/system[1]/pipeline/pipeline_pressure gt 100
			</test>
		</switch>

		<actuator name="fcs/left-elevator-pos-hyd">
            <input>fcs/left-elevator-pos-rad</input>
            <rate_limit sense="decr">fcs/left-elevator-pos-hyd-rate</rate_limit> 
            <rate_limit sense="incr">fcs/left-elevator-pos-hyd-rate</rate_limit>  
        </actuator>

		<fcs_function name="fcs/left-elevator-pos-hyd-rate-low">
			<function>
                          <sum>
                            <value>0.3</value>
				<quotient>
					<property>/systems/hydraulic/system[1]/pipeline/pipeline_pressure</property>
					<value>8000</value>
				</quotient>
                            </sum>
			</function>
		</fcs_function>

		<fcs_function name="fcs/left-elevator-pos-hyd-rate-high">
			<function>
				<quotient>
					<property>/systems/hydraulic/system[1]/pipeline/pipeline_pressure</property>
					<value>3000</value>
				</quotient>
			</function>
                        <clipto> 
                 	 <max>1.0</max> 
                 	 <min>0.0</min> 
                	</clipto>
		</fcs_function>

		<fcs_function name="fcs/left-elevator-pos-hyd-rate">
			<function>
                            <ifthen>
                             <lt>
                              <property>/systems/hydraulic/system[1]/pipeline/pipeline_pressure</property>
                              <value>1601</value>
                             </lt>
                		<property>fcs/left-elevator-pos-hyd-rate-low</property>
                		<property>fcs/left-elevator-pos-hyd-rate-high</property>
                            </ifthen>                                   
			</function>
		</fcs_function>

        <aerosurface_scale name="fcs/left-elevator-pos-norm">
            <input>fcs/left-elevator-pos-input</input>
            <domain>
                <min>-0.35</min>
                <max>0.35</max>
            </domain>
            <range>
                <min>-1</min>
                <max>1</max>
            </range>
            <output>/surface-positions/left-elevator-pos-norm</output>
        </aerosurface_scale>

        <aerosurface_scale name="Right Elevator Control">
            <input>fcs/right-elevon-sum</input>
            <range>
                <min>-0.35</min>
                <max>0.35</max>
            </range>
            <output>fcs/right-elevator-pos-rad</output>
        </aerosurface_scale>

		<actuator name="fcs/right-elevator-pos-mech">
            <input>fcs/right-elevator-pos-rad</input>
            <rate_limit sense="decr">0.1</rate_limit> 
            <rate_limit sense="incr">0.1</rate_limit> 
        </actuator>

		<switch name="fcs/right-elevator-pos-input">
			<default value="fcs/right-elevator-pos-mech"/>
			<test logic="AND" value="fcs/right-elevator-pos-hyd">
                                /systems/hydraulic/system[1]/pipeline/pipeline_pressure gt 100
			</test>
		</switch>

		<actuator name="fcs/right-elevator-pos-hyd">
            <input>fcs/right-elevator-pos-rad</input>
            <rate_limit sense="decr">fcs/right-elevator-pos-hyd-rate</rate_limit> 
            <rate_limit sense="incr">fcs/right-elevator-pos-hyd-rate</rate_limit> 
        </actuator>

		<fcs_function name="fcs/right-elevator-pos-hyd-rate-low">
			<function>
                          <sum>
                            <value>0.3</value>
				<quotient>
					<property>/systems/hydraulic/system[1]/pipeline/pipeline_pressure</property>
					<value>8000</value>
				</quotient>
                            </sum>
			</function>
		</fcs_function>
		<fcs_function name="fcs/right-elevator-pos-hyd-rate-high">
			<function>
				<quotient>
					<property>/systems/hydraulic/system[1]/pipeline/pipeline_pressure</property>
					<value>3000</value>
				</quotient>
			</function>
                        <clipto> 
                 	 <max>1.0</max> 
                 	 <min>0.0</min> 
                	</clipto>
		</fcs_function>

		<fcs_function name="fcs/right-elevator-pos-hyd-rate">
			<function>
                            <ifthen>
                             <lt>
                              <property>/systems/hydraulic/system[1]/pipeline/pipeline_pressure</property>
                              <value>1601</value>
                             </lt>
                		<property>fcs/right-elevator-pos-hyd-rate-low</property>
                		<property>fcs/right-elevator-pos-hyd-rate-high</property>
                            </ifthen>                                   
			</function>
		</fcs_function>

        <aerosurface_scale name="fcs/right-elevator-pos-norm">
            <input>fcs/right-elevator-pos-input</input>
            <domain>
                <min>-0.35</min>
                <max>0.35</max>
            </domain>
            <range>
                <min>-1</min>
                <max>1</max>
            </range>
            <output>/surface-positions/right-elevator-pos-norm</output>
        </aerosurface_scale>

        <summer name="fcs/elevator-pos-norm-sum">
            <input>fcs/left-elevator-pos-norm</input>
            <input>fcs/right-elevator-pos-norm</input>
        </summer>
        <pure_gain name="fcs/elevator-pos-norm">
            <input>fcs/elevator-pos-norm-sum</input>
            <gain>0.5</gain>
        </pure_gain>
        <summer name="fcs/elevator-pos-rad-sum">
            <input>fcs/left-elevator-pos-rad</input>
            <input>fcs/right-elevator-pos-rad</input>
        </summer>
        <pure_gain name="fcs/elevator-pos-rad">
            <input>fcs/elevator-pos-norm-sum</input>
            <gain>0.5</gain>
        </pure_gain>

        <summer name="fcs/aileron-pos-sum">
            <input>-fcs/left-elevator-pos-rad</input>
            <input>fcs/right-elevator-pos-rad</input>
        </summer>
        <pure_gain name="fcs/aileron-pos-rad">
            <input>fcs/aileron-pos-sum</input>
            <gain>0.5</gain>
        </pure_gain>
    </channel>

    <property value="1">fcs/yaw-damper-enable</property>
    <channel name="Yaw">

        <summer name="Rudder Command Sum">
            <input>fcs/rudder-cmd-norm</input>
            <input>fcs/yaw-trim-cmd-norm</input>
            <clipto>
                <min>-1</min>
                <max>1</max>
            </clipto>
        </summer>

        <scheduled_gain name="Yaw Damper Rate">
            <input>velocities/r-aero-rad_sec</input>
            <table>
                <independentVar lookup="row">velocities/ve-kts</independentVar>
                <tableData>
                    30 0.00
                    60 2.00
                </tableData>
            </table>
            <gain>fcs/yaw-damper-enable</gain>
        </scheduled_gain>

        <summer name="Rudder Sum">
            <input>fcs/rudder-command-sum</input>
            <input>fcs/yaw-damper-rate</input>
            <clipto>
                <min>-1.1</min>
                <max>1.1</max>
            </clipto>
        </summer>

        <aerosurface_scale name="Rudder Control">
            <input>fcs/rudder-sum</input>
            <domain>
                <min>-1.1</min>
                <max>1.1</max>
            </domain>
            <range>
                <min>-0.35</min>
                <max>0.35</max>
            </range>
            <output>fcs/rudder-pos-rad</output>
        </aerosurface_scale>

		<actuator name="fcs/rudder-pos-mech">
            <input>fcs/rudder-pos-rad</input>
            <rate_limit sense="decr">0.3</rate_limit> 
            <rate_limit sense="incr">0.3</rate_limit> 
        </actuator>

		<switch name="fcs/rudder-pos-input">
			<default value="fcs/rudder-pos-mech"/>
			<test logic="AND" value="fcs/rudder-pos-hyd">
                                /systems/hydraulic/system[1]/pipeline/pipeline_pressure gt 100
			</test>
		</switch>

		<actuator name="fcs/rudder-pos-hyd">
            <input>fcs/rudder-pos-rad</input>
            <rate_limit sense="decr">fcs/rudder-pos-hyd-rate</rate_limit> 
            <rate_limit sense="incr">fcs/rudder-pos-hyd-rate</rate_limit> 
        </actuator>

		<fcs_function name="fcs/rudder-pos-hyd-rate-low">
			<function>
                          <sum>
                            <value>0.3</value>
				<quotient>
					<property>/systems/hydraulic/system[1]/pipeline/pipeline_pressure</property>
					<value>8000</value>
				</quotient>
                            </sum>
			</function>
		</fcs_function>
		<fcs_function name="fcs/rudder-pos-hyd-rate-high">
			<function>
				<quotient>
					<property>/systems/hydraulic/system[1]/pipeline/pipeline_pressure</property>
					<value>3000</value>
				</quotient>
			</function>
                        <clipto> 
                 	 <max>1.0</max> 
                 	 <min>0.0</min> 
                	</clipto>
		</fcs_function>

		<fcs_function name="fcs/rudder-pos-hyd-rate">
			<function>
                            <ifthen>
                             <lt>
                              <property>/systems/hydraulic/system[1]/pipeline/pipeline_pressure</property>
                              <value>1601</value>
                             </lt>
                		<property>fcs/rudder-pos-hyd-rate-low</property>
                		<property>fcs/rudder-pos-hyd-rate-high</property>
                            </ifthen>                                   
			</function>
		</fcs_function>

        <aerosurface_scale name="rudder normalization">
            <input>fcs/rudder-pos-input</input>
            <domain>
                <min>-0.35</min>
                <max>0.35</max>
            </domain>
            <range>
                <min>-1</min>
                <max>1</max>
            </range>
            <output>fcs/rudder-pos-norm</output>
        </aerosurface_scale>



    </channel>

    <channel name="Flaps">
        <kinematic name="Flaps Control">
            <input>fcs/flap-cmd-norm</input>
            <traverse>
                <setting>
                    <position>0</position>
                    <time>0</time>
                </setting>
                <setting>
                    <position>15</position>
                    <time>10</time>
                </setting>
                <setting>
                    <position>30</position>
                    <time>10</time>
                </setting>
            </traverse>
            <output>fcs/flap-pos-deg</output>
        </kinematic>

		<actuator name="fcs/flap-pos-rate">
            <input>fcs/flap-pos-deg</input>
            <rate_limit sense="decr">fcs/flap-pos-rate-switch</rate_limit> 
            <rate_limit sense="incr">fcs/flap-pos-rate-switch</rate_limit> 
        </actuator>

		<switch name="fcs/flap-pos-rate-switch">
			<default value="2"/>
			<test logic="AND" value="0.0">
                                /systems/flight-controls/flaps/channel-1 eq 1
                                /systems/flight-controls/flaps/channel-2 eq 1
			</test>
			<test logic="AND" value="0.8">
                                /systems/flight-controls/flaps/channel-1 eq 1
			</test>
		</switch>

		<switch name="/systems/flight-controls/flaps/channel-1">
			<default value="0"/>
			<test logic="OR" value="1">
                                /systems/hydraulic/system[1]/pipeline/pipeline_pressure lt 2000
                                /systems/hydraulic/system[4]/pipeline/pipeline_pressure lt 2000
			 </test>
			<test logic="AND" value="1">
                                fcs/flap-pos-norm gt 0
                                /accelerations/pilot-g gt 2
			</test>
		</switch>

		<switch name="/systems/flight-controls/flaps/channel-2">
			<default value="0"/>
			<test logic="AND" value="1">
                                /systems/hydraulic/system[1]/pipeline/pipeline_pressure lt 500
                                /systems/hydraulic/system[4]/pipeline/pipeline_pressure lt 500
			 </test>
			<test logic="AND" value="1">
                                fcs/flap-pos-norm gt 0
                                /accelerations/pilot-g gt 2
		        </test>
		</switch>

        <aerosurface_scale name="flap normalization">
            <input>fcs/flap-pos-rate</input>
            <domain>
                <min>0</min>
                <max>30</max>
            </domain>
            <range>
                <min>0</min>
                <max>1</max>
            </range>
            <output>fcs/flap-pos-norm</output>
        </aerosurface_scale>

    </channel>

    <channel name="Landing Gear">
        <switch name="fcs/gear-no-wow">
            <default value="1"/>
            <test logic="AND" value="0">
                gear/unit[1]/WOW eq 1
                gear/unit[2]/WOW eq 1
            </test>
        </switch>

        <kinematic name="Gear Control">
            <input>gear/gear-cmd-norm</input>
            <traverse>
                <setting>
                    <position>0</position>
                    <time>0</time>
                </setting>
                <setting>
                    <position>1</position>
                    <time>5</time>
                </setting>
            </traverse>
            <output>gear/gear-pos-norm</output>
        </kinematic>

	<switch name="fcs/steer-pos-deg">
		<test value="fcs/steer-pos-alter">
		   /controls/switches/nose-wheel-steering-switch eq 0
		</test>
		<default value="fcs/steer-pos-deg"/>
        </switch>

		<fcs_function name="fcs/steer-pos-alter">
			<function>
				<product>
					<value>30</value>
					<property>fcs/steer-cmd-norm</property>
				</product>
			</function>
		</fcs_function> 

    </channel>

    <channel name="Speedbrake">
        <kinematic name="Speedbrake Control">
            <input>fcs/speedbrake-cmd-norm</input>
            <traverse>
                <setting>
                    <position>0</position>
                    <time>0</time>
                </setting>
                <setting>
                    <position>1</position>
                    <time>1</time>
                </setting>
            </traverse>
            <output>fcs/speedbrake-pos-norm</output>
        </kinematic>

    </channel>
    <channel name="Spoilers">
        <kinematic name="Spoilers Control">
            <input>fcs/spoiler-cmd-norm</input>
            <traverse>
                <setting>
                    <position>0</position>
                    <time>0</time>
                </setting>
                <setting>
                    <position>1</position>
                    <time>1</time>
                </setting>
            </traverse>
            <output>fcs/spoilers-pos-norm</output>
        </kinematic>
    </channel>

</system>