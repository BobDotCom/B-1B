<?xml version="1.0" encoding="UTF-8"?>
<PropertyList>  
  <filter>
    <name>CRT Contrast</name> <!-- Stolen from MD-11 thanks Josh -->
    <type>gain</type>
    <gain>1.0</gain>
    <input>
      <expression>
        <table>
          <property>/rendering/scene/diffuse/red</property>
          <entry><ind>0.8</ind><dep>0.85</dep></entry>
          <entry><ind>0.0</ind><dep>0.96</dep></entry>
        </table>
      </expression>
    </input>
    <output>/instrumentation/crt/contrast</output>
  </filter>
</PropertyList>
