		<switch name="/systems/computers/adc_switch/true_airspeed_knts_output">
			<default value="/systems/computers/adc[0]/airspeed/true_airspeed_knts"/>			
                	<test logic="AND" value="/systems/computers/adc[1]/airspeed/true_airspeed_knts">
					/controls/switches/ADC-select-switch eq 1
			</test>
		</switch>

		<switch name="/systems/computers/adc_switch/indicated_airspeed_knts_output">
			<default value="/systems/computers/adc[0]/airspeed/indicated_airspeed_knts"/>			
                	<test logic="AND" value="/systems/computers/adc[1]/airspeed/indicated_airspeed_knts">
					/controls/switches/ADC-select-switch eq 1
			</test>
		</switch>


</channel>

<channel name="HSI" execrate="8">

            <!-- Needle -->

            <!-- Miles drums -->

		<switch name="/systems/computers/hsi/miles_drums_output_switch">
			<default value="0"/>
                	<test logic="AND" value="/autopilot/route-manager/wp/dist">
					/controls/switches/fltdir eq 0.2
					/autopilot/route-manager/active eq 1
			</test>			
                	<test logic="AND" value="/instrumentation/nav/nav-distance">
					/controls/switches/fltdir eq 0.4
					/instrumentation/nav/in-range eq 1
			</test>
                	<test logic="AND" value="/instrumentation/tacan/indicated-distance-nm">
					/controls/switches/fltdir eq 0.5
					/instrumentation/tacan/in-range eq 1
			</test>
		</switch>

		<switch name="/systems/computers/hsi/miles_drums_rate">
			<default value="0"/>			
                	<test logic="AND" value="10000">
					/systems/failures/computers/hsi/miles_drums ne 1
					/systems/electrical/bus/ac-3/voltage gt 225
					/systems/computers/hsi/miles_drums_output_switch ne 0
			</test>
		</switch>

		<actuator name="/systems/computers/hsi/miles_drums_output">
            		<input>/systems/computers/hsi/miles_drums_output_switch</input>
            		<rate_limit sense="decr">/systems/computers/hsi/miles_drums_rate</rate_limit> 
            		<rate_limit sense="incr">/systems/computers/hsi/miles_drums_rate</rate_limit> 
       		</actuator>

</channel>

</system>