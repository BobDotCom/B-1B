<channel name="HSI" execrate="8">

            <!-- Needle -->

		<switch name="/systems/computers/hsi/bearing-needle/current-value">
			<default value="0"/>
                	<test logic="AND" value="/instrumentation/adf/indicated-bearing-deg">
					/instrumentation/adf/in-range eq 1
					/controls/switches/fltdir eq 0.3
			</test>	
		        <test logic="AND" value="/instrumentation/tacan/indicated-bearing-offset-deg">
					/instrumentation/tacan/in-range eq 1
					/controls/switches/fltdir eq 0.5
			</test>
		</switch>
		<switch name="/systems/computers/hsi/bearing-needle/rate">
			<default value="0"/>
                	<test logic="OR" value="50">
				/systems/electrical/bus/ac-3/voltage gt 225
				/systems/electrical/bus/ess/voltage gt 225
			</test>			
		</switch>
		<actuator name="/systems/computers/hsi/bearing-needle/output">
            		<input>/systems/computers/hsi/bearing-needle/current-value</input>
            		<rate_limit sense="decr">/systems/computers/hsi/bearing-needle/rate</rate_limit> 
            		<rate_limit sense="incr">/systems/computers/hsi/bearing-needle/rate</rate_limit> 
       		</actuator>

		<fcs_function name="/instrumentation/tacan/indicated-bearing-offset-deg">
			<function>
			 <product>
				<difference>
					<property>/orientation/heading-magnetic-deg</property>
					<property>/instrumentation/tacan/indicated-bearing-true-deg</property>
				</difference>
                                <value>-1</value> 
                         </product>
			</function>
			<min>-180</min>
			<max>180</max>
		</fcs_function>

            <!-- Miles drums -->

		<fcs_function name="/instrumentation/nav/nav-distance-mi">
			<function>
				<product>
					<property>/instrumentation/nav/nav-distance</property>
					<value>0.000621371</value>
				</product>
			</function>
		</fcs_function>

		<switch name="/systems/computers/hsi/miles_drums/output_value">
			<default value="0"/>
                	<test logic="AND" value="/autopilot/route-manager/wp/dist">
					/controls/switches/fltdir eq 0.2
					/autopilot/route-manager/active eq 1
			</test>			
                	<test logic="AND" value="/instrumentation/nav/nav-distance-mi">
					/controls/switches/fltdir eq 0.4
					/instrumentation/nav/in-range eq 1
			</test>
                	<test logic="AND" value="/instrumentation/tacan/indicated-distance-nm">
					/controls/switches/fltdir eq 0.5
					/instrumentation/tacan/in-range eq 1
			</test>
		</switch>

		<switch name="/systems/computers/hsi/miles_drums/rate">
			<default value="0"/>			
                	<test logic="AND" value="5">
					/systems/failures/computers/hsi/miles_drums ne 1
					/systems/electrical/bus/ac-3/voltage gt 225
					/systems/computers/hsi/miles_drums/output_value ne 0
			</test>
		</switch>

		<actuator name="/systems/computers/hsi/miles_drums/output">
            		<input>/systems/computers/hsi/miles_drums/output_value</input>
            		<rate_limit sense="decr">/systems/computers/hsi/miles_drums/rate</rate_limit> 
            		<rate_limit sense="incr">/systems/computers/hsi/miles_drums/rate</rate_limit> 
       		</actuator>

</channel>

<channel name="Radar Altitude" execrate="8">

           <!-- Altitude radars and panel -->

           <!-- Altimeter 1 -->

		<switch name="/systems/computers/altitude_radars/altitude_radar[0]/output">
			<default value="0"/>
                	<test logic="AND" value="/instrumentation/radar-altimeter/radar-altitude-ft">
					/systems/electrical/bus/ac-1/voltage gt 220
					/systems/failures/computers/altitude_radars/altitude_radar[0] eq 0
					/systems/computers/altitude_radars/altitude_radar[0]/warm_up/warm_up eq 1
			</test>				
		</switch>

           <!-- Altimeter 1 warm up period-->

		<switch name="/systems/computers/altitude_radars/altitude_radar[0]/warm_up/warm_up_target">
			<default value="0"/>
                	<test logic="AND" value="1">
					/systems/electrical/bus/ac-1/voltage gt 220
                	<test logic="OR">
					/instrumentation/radar-altimeter/altimeter_switch eq 1
					/instrumentation/radar-altimeter/altimeter_switch eq 2
			 </test>	
			</test>		
		</switch>

		<actuator name="/systems/computers/altitude_radars/altitude_radar[0]/warm_up/warm_up">
            		<input>/systems/computers/altitude_radars/altitude_radar[0]/warm_up/warm_up_target</input>
            		<rate_limit sense="decr">0.0053</rate_limit> <!-- Three minutes-->
            		<rate_limit sense="incr">0.0053</rate_limit> <!-- Three minutes-->
       		</actuator>

           <!-- Altimeter 2 -->

		<switch name="/systems/computers/altitude_radars/altitude_radar[1]/output">
			<default value="0"/>
                	<test logic="AND" value="/instrumentation/radar-altimeter/radar-altitude-ft">
					/systems/electrical/bus/ac-3/voltage gt 220 
					/systems/failures/computers/altitude_radars/altitude_radar[1] eq 0
					/systems/computers/altitude_radars/altitude_radar[1]/warm_up/warm_up eq 1
			</test>				
		</switch>

           <!-- Altimeter 2 warm up period-->

		<switch name="/systems/computers/altitude_radars/altitude_radar[1]/warm_up/warm_up_target">
			<default value="0"/>
                	<test logic="AND" value="1">
					/systems/electrical/bus/ac-3/voltage gt 220
                	<test logic="OR">
					/instrumentation/radar-altimeter/altimeter_switch ge 2
			 </test>
			</test>			
		</switch>

		<actuator name="/systems/computers/altitude_radars/altitude_radar[1]/warm_up/warm_up">
            		<input>/systems/computers/altitude_radars/altitude_radar[1]/warm_up/warm_up_target</input>
            		<rate_limit sense="decr">0.0053</rate_limit> <!-- Three minutes-->
            		<rate_limit sense="incr">0.0053</rate_limit> <!-- Three minutes-->
       		</actuator>

           <!-- Altimeter panel switch-->

		<switch name="/instrumentation/radar-altimeter/serviceable">
			<default value="0"/>
                	<test logic="AND" value="1">
				/instrumentation/radar-altimeter/altimeter_switch gt 0
			</test>				
		</switch>

		<fcs_function name="/systems/computers/altitude_radars/altitude_radar_switch/auto_function">
			<function>
					<max>
						<property>/systems/computers/altitude_radars/altitude_radar[0]/output</property>
						<property>/systems/computers/altitude_radars/altitude_radar[1]/output</property>
					</max>
			</function>
		</fcs_function>


		<switch name="/systems/computers/altitude_radars/altitude_radar_switch/current_value">
			<default value="0"/>
                	<test logic="AND" value="/systems/computers/altitude_radars/altitude_radar[0]/output">
					/instrumentation/radar-altimeter/altimeter_switch eq 1
			 </test>
                	<test logic="AND" value="/systems/computers/altitude_radars/altitude_radar_switch/auto_function">
					/instrumentation/radar-altimeter/altimeter_switch eq 2
			 </test>
                	<test logic="AND" value="/systems/computers/altitude_radars/altitude_radar[1]/output">
					/instrumentation/radar-altimeter/altimeter_switch eq 3
			 </test>		
		</switch>


           <!-- Altimeter dial rate-->

		<actuator name="/systems/computers/altitude_radars/dial_needle_rate">
            		<input>/systems/computers/altitude_radars/altitude_radar_switch/current_value</input>
            		<rate_limit sense="decr">250</rate_limit>
            		<rate_limit sense="incr">250</rate_limit>
       		</actuator>

</channel>

</system>