		<actuator name="/systems/computers/gss[0]/startup_timer">
            		<input>/systems/computers/gss[0]/startup_timer_limits</input>
            		<rate_limit sense="decr">1</rate_limit> 
            		<rate_limit sense="incr">1</rate_limit> 
       		</actuator>

		<switch name="/systems/computers/gss[0]/startup_timer_limits">
			<default value="0"/>			
                	<test logic="AND" value="20">
					/systems/electrical/bus/ess/voltage gt 225					
			</test>
		</switch>

            <!-- Heading -->

		<switch name="/systems/computers/gss[0]/heading/heading_error/target">
			<default value="/orientation/heading-deg"/>			
                	<test logic="AND" value="0">
					/systems/electrical/bus/ess/voltage gt 225
			</test>
		</switch>

		<actuator name="/systems/computers/gss[0]/heading/heading_error">
            		<input>/systems/computers/gss[0]/heading/heading_error/target</input>
            		<rate_limit sense="decr">/systems/computers/gss[0]/heading/heading_error/degree_per_sec</rate_limit> 
            		<rate_limit sense="incr">/systems/computers/gss[0]/heading/heading_error/degree_per_sec</rate_limit> 
       		</actuator>


		<fcs_function name="/systems/computers/gss[0]/heading/heading_error/degree_per_sec">
			<function>
				<quotient>
					<property>/orientation/heading-deg</property>
					<value>20</value>
				</quotient>
			</function>
		</fcs_function> 

		<fcs_function name="/systems/computers/gss[0]/heading/output">
			<function>
				<difference>
					<property>/orientation/heading-deg</property>
					<property>/systems/computers/gss[0]/heading/heading_error</property>
				</difference>
			</function>
		</fcs_function> 

            <!-- Pitch -->

            <!-- Start up Error -->

		<switch name="/systems/computers/gss[0]/pitch/pitch_error/error_value_switch">
