    <property value="0">/systems/failures/hydraulic/system[1]/pump_2_failure-trigger</property>
    <property value="0">/systems/failures/hydraulic/system[2]/fluid-leak-trigger</property>
    <property value="0">/systems/failures/hydraulic/system[2]/pump_1_failure-trigger</property>
    <property value="0">/systems/failures/hydraulic/system[2]/pump_2_failure-trigger</property>
    <property value="0">/systems/failures/hydraulic/system[3]/fluid-leak-trigger</property>
