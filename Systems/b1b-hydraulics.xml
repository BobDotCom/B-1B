    <property value="0">/systems/failures/hydraulic/system[3]/pump_2_failure-trigger</property>
    <property value="0">/systems/failures/hydraulic/system[4]/fluid-leak-trigger</property>
    <property value="0">/systems/failures/hydraulic/system[4]/pump_1_failure-trigger</property>
    <property value="0">/systems/failures/hydraulic/system[4]/pump_2_failure-trigger</property>

	<channel name="Hydraulic pumps" execrate="8">

<!-- System 1 --> 

<!-- Pump 1 --> 
  
<!-- Pressure increase rate--> 

		<fcs_function name="/systems/hydraulic/system[1]/pumps/pump[1]/pressure_from_APU">
			<function>
				<product>
					<value>27</value>
					<property>/systems/engines/adg[0]/drive-rpm</property>
				</product>
			</function>
			<clipto>
				<min>0</min>
				<max>1600</max>
			</clipto>
		</fcs_function>

		<fcs_function name="/systems/hydraulic/system[1]/pumps/pump[1]/deceleration_rate">
			<function>
				<product>
					<value>25</value>
					<property>/systems/engines/adg[0]/drive-rpm</property>
				</product>
			</function>
			<clipto>
				<min>1.1</min>
				<max>1600</max>
			</clipto>
		</fcs_function>

		<switch name="/systems/hydraulic/system[1]/pumps/pump[1]/final_pressure">
			<default value="0"/>
			<test logic="AND" value="/systems/hydraulic/system[1]/pumps/pump[1]/engine_pressure">
                                /engines/engine[0]/n2 ge 0.1
			</test>
			<test logic="AND" value="/systems/hydraulic/system[1]/pumps/pump[1]/pressure_from_APU">
                                /systems/engines/adg[0]/drive-rpm ge 1
			</test>
		</switch>

		<switch name="/systems/hydraulic/system[1]/pumps/pump[1]/engine_pressure">
			<default value="/systems/hydraulic/system[1]/pumps/pump[1]/pressure_from_APU"/>
			<test logic="AND" value="/systems/hydraulic/system[1]/pumps/pump[1]/engine_pressure_input_rate">
                                /engines/engine[0]/n2 ge 0.1
			</test>
		</switch>

		<switch name="/systems/hydraulic/system[1]/pumps/pump[1]/engine_pressure_input">
			<default value="/systems/hydraulic/system[1]/pumps/pump[1]/pressure_from_APU"/>
			<test logic="AND" value="4000">
                                /engines/engine[0]/running eq 1
			</test>
		</switch>

		<actuator name="/systems/hydraulic/system[1]/pumps/pump[1]/engine_pressure_input_rate">
            <input>/systems/hydraulic/system[1]/pumps/pump[1]/engine_pressure_input</input>
            <rate_limit sense="decr">/systems/hydraulic/system[1]/pumps/pump[1]/deceleration_rate</rate_limit> 
            <rate_limit sense="incr">600</rate_limit> 
        </actuator>

